<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sample_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/sample_surface_emphasis"
            app:cardCornerRadius="20dp"
            app:strokeColor="@color/sample_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/title"
                    android:textAppearance="?attr/textAppearanceHeadline5"
                    android:textColor="@color/sample_text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/description"
                    android:textAppearance="?attr/textAppearanceBody1"
                    android:textColor="@color/sample_text_secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/sample_surface"
            app:cardCornerRadius="20dp"
            app:strokeColor="@color/sample_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/usage_title"
                    android:textAppearance="?attr/textAppearanceSubtitle1"
                    android:textColor="@color/sample_text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/usage_body"
                    android:textAppearance="?attr/textAppearanceBody2"
                    android:textColor="@color/sample_text_secondary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/usage_init_label"
                    android:textAppearance="?attr/textAppearanceCaption"
                    android:textColor="@color/sample_text_muted" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@color/sample_code_background"
                    android:fontFamily="monospace"
                    android:padding="12dp"
                    android:text="@string/usage_init_snippet"
                    android:textAppearance="?attr/textAppearanceBody2"
                    android:textColor="@color/sample_text_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/usage_logging_label"
                    android:textAppearance="?attr/textAppearanceCaption"
                    android:textColor="@color/sample_text_muted" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@color/sample_code_background"
                    android:fontFamily="monospace"
                    android:padding="12dp"
                    android:text="@string/usage_logging_snippet"
                    android:textAppearance="?attr/textAppearanceBody2"
                    android:textColor="@color/sample_text_primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/sample_surface"
            app:cardCornerRadius="20dp"
            app:strokeColor="@color/sample_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/key_section_title"
                    android:textAppearance="?attr/textAppearanceSubtitle1"
                    android:textColor="@color/sample_text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/key_section_body"
                    android:textAppearance="?attr/textAppearanceBody2"
                    android:textColor="@color/sample_text_secondary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/encryption_status_label"
                    android:textAppearance="?attr/textAppearanceCaption"
                    android:textColor="@color/sample_text_muted" />

                <TextView
                    android:id="@+id/encryptionStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceBody1"
                    android:textColor="@color/sample_text_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/exported_key_label"
                    android:textAppearance="?attr/textAppearanceCaption"
                    android:textColor="@color/sample_text_muted" />

                <TextView
                    android:id="@+id/keyValueText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@color/sample_code_background"
                    android:fontFamily="monospace"
                    android:padding="12dp"
                    android:text="@string/key_unavailable"
                    android:textAppearance="?attr/textAppearanceBody2"
                    android:textColor="@color/sample_text_primary"
                    android:textIsSelectable="true" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/decrypt_command_label"
                    android:textAppearance="?attr/textAppearanceCaption"
                    android:textColor="@color/sample_text_muted" />

                <TextView
                    android:id="@+id/decryptCommandText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@color/sample_code_background"
                    android:fontFamily="monospace"
                    android:padding="12dp"
                    android:textAppearance="?attr/textAppearanceBody2"
                    android:textColor="@color/sample_text_primary"
                    android:textIsSelectable="true" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/sample_surface"
            app:cardCornerRadius="20dp"
            app:strokeColor="@color/sample_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/actions_title"
                    android:textAppearance="?attr/textAppearanceSubtitle1"
                    android:textColor="@color/sample_text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/actions_body"
                    android:textAppearance="?attr/textAppearanceBody2"
                    android:textColor="@color/sample_text_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/copyKeyButton"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/copy_key"
                    android:textAllCaps="false"
                    android:textColor="@color/sample_button_text"
                    app:backgroundTint="@color/sample_accent" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/test_report_hint"
                    android:textAppearance="?attr/textAppearanceBody2"
                    android:textColor="@color/sample_text_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/testReportButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/generate_test_report"
                    android:textAllCaps="false"
                    android:textColor="@color/sample_text_primary"
                    app:strokeColor="@color/sample_stroke" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/crash_hint"
                    android:textAppearance="?attr/textAppearanceBody2"
                    android:textColor="@color/sample_text_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/crashAppButton"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/crash_app"
                    android:textAllCaps="false"
                    android:textColor="@color/sample_text_primary"
                    app:backgroundTint="@color/sample_danger" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
